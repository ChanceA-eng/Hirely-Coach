  "lessons": [
    {
      "id": "4-1",
      "type": "lesson_card",
      "title": "Introduction: Pronouns and Verbs",
      "title_sw": "Utangulizi: Viwakilishi na Vitenzi",
      "instruction_sw": "Somo hili linaeleza aina za viwakilishi na vitenzi vya msingi kwa matumizi ya sentensi.",
      "instruction_en": "This lesson introduces pronoun types and core verbs for sentence building.",
      "content": [
        {
          "label": "Pronouns",
          "label_sw": "Viwakilishi",
          "explanation": "Pronouns replace nouns to avoid repetition and make sentences easier to understand.",
          "explanation_sw": "Viwakilishi huchukua nafasi ya nomino ili kuepuka kurudia maneno na kurahisisha sentensi kueleweka.",
          "examples": ["I am ready.", "She is here.", "They are working."],
          "examples_sw": ["Mimi niko tayari.", "Yeye yupo hapa.", "Wao wanafanya kazi."]
        },
        {
          "label": "Verbs",
          "label_sw": "Vitenzi",
          "explanation": "Verbs are action words that show what a person or thing does.",
          "explanation_sw": "Vitenzi ni maneno ya tendo yanayoonyesha mtu au kitu kinafanya nini.",
          "examples": ["eat", "work", "talk"],
          "examples_sw": ["kula", "kufanya kazi", "kuzungumza"]
        }
      ],
      "common_mistakes": [
        {
          "wrong": "Me am ready",
          "right": "I am ready",
          "explanation": "Use subject pronoun 'I' before a verb in a sentence.",
          "explanation_sw": "Tumia subject pronoun 'I' kabla ya kitenzi kwenye sentensi."
        }
      ],
      "practice_sentences": [
        { "en": "She eats an apple.", "sw": "Yeye anakula tofaa." },
        { "en": "We work together.", "sw": "Sisi tunafanya kazi pamoja." }
      ]
    },
